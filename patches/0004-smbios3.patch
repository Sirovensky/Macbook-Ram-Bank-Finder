diff --git a/system/smbios.c b/system/smbios.c
index c42813a..8b75c48 100644
--- a/system/smbios.c
+++ b/system/smbios.c
@@ -20,9 +20,52 @@ static uint32_t table_length = 0; // 16-bit in SMBIOS v2, 32-bit in SMBIOS v3.
 static const efi_guid_t SMBIOS2_GUID = { 0xeb9d2d31, 0x2d88, 0x11d3, {0x9a, 0x16, 0x00, 0x90, 0x27, 0x3f, 0xc1, 0x4d} };
 
 // SMBIOS v3 compliant FW must include an SMBIOS v2 table, but maybe parse SM3 table later...
-// static const efi_guid_t SMBIOS3_GUID = { 0xf2fd1544, 0x9794, 0x4a2c, {0x99, 0x2e, 0xe5, 0xbb, 0xcf, 0x20, 0xe3, 0x94} };
+static const efi_guid_t SMBIOS3_GUID = { 0xf2fd1544, 0x9794, 0x4a2c, {0x99, 0x2e, 0xe5, 0xbb, 0xcf, 0x20, 0xe3, 0x94} };
+
+// SMBIOS 3.x (64-bit) entry-point anchor layout, per DSP0134:
+//   [0x00] "_SM3_"  (5 bytes)
+//   [0x05] checksum (1 byte)
+//   [0x06] length   (1 byte, 0x18)
+//   [0x07] major    (1 byte)
+//   [0x08] minor    (1 byte)
+//   [0x0C] table_max_length (4 bytes, LE)
+//   [0x10] table_address    (8 bytes, LE)
+// Apple EFI on T2 Macs (e.g. MacBookPro15,x) only publishes this variant.
+static uintptr_t parse_smbios3_anchor(const uint8_t *ep, uint32_t *out_len)
+{
+    if (ep == NULL) return 0;
+    if (!(ep[0]=='_' && ep[1]=='S' && ep[2]=='M' && ep[3]=='3' && ep[4]=='_'))
+        return 0;
+    *out_len = ep[0x0C] | (ep[0x0D]<<8) | (ep[0x0E]<<16) | ((uint32_t)ep[0x0F]<<24);
+    uint64_t addr = 0;
+    for (int i = 0; i < 8; i++) addr |= ((uint64_t)ep[0x10 + i]) << (i*8);
+    return (uintptr_t)addr;
+}
 
 struct system_info *dmi_system_info;
+
+// Debug: expose which path smbios_init took. 0=none, 2=v2, 3=v3.
+// Set to negative values for specific failure cases.
+//   -1 = no config table found
+//   -3 = v3 anchor bytes invalid
+//   -4 = v3 table_addr/tlen zero
+//   -5 = v3 map_region for table failed
+//   -6 = v2 checksum failed
+//   -7 = v2 version below 2.3
+int smbios_init_source = 0;
+uintptr_t smbios_init_ep_addr = 0;
+uint32_t  smbios_init_table_len = 0;
+
+// Bytes remaining from p to end of parsed SMBIOS table. Returns 0 if p is
+// outside the table. Used by external consumers that need a valid maxlen
+// for get_tstruct_string() without knowing table_start directly.
+uint32_t smbios_table_remaining(const void *p)
+{
+    const uint8_t *q = (const uint8_t *)p;
+    if (!table_start || !table_length) return 0;
+    if (q < table_start || q >= table_start + table_length) return 0;
+    return (uint32_t)((table_start + table_length) - q);
+}
 struct baseboard_info *dmi_baseboard_info;
 struct mem_dev *dmi_memory_device;
 
@@ -43,18 +86,31 @@ static char *get_tstruct_string(struct tstruct_header *header, uint16_t maxlen,
 }
 
 #if (ARCH_BITS == 64)
-static smbiosv2_t *find_smbiosv2_in_efi64_system_table(efi64_system_table_t *system_table)
+// Locate SMBIOS entry point in the EFI config table. Prefer v3 anchor when
+// available (Apple T2 Macs only publish v3); fall back to v2.
+static uintptr_t find_smbios_ep_efi64(efi64_system_table_t *system_table, int *is_v3)
 {
     efi64_config_table_t *config_tables = (efi64_config_table_t *) map_region(system_table->config_tables, system_table->num_config_tables * sizeof(efi64_config_table_t), true);
-    if (config_tables == NULL) return NULL;
+    if (config_tables == NULL) return 0;
 
-    uintptr_t table_addr = 0;
+    uintptr_t v2 = 0, v3 = 0;
     for (uint32_t i = 0; i < system_table->num_config_tables; i++) {
-        if (memcmp( & config_tables[i].guid, & SMBIOS2_GUID, sizeof(efi_guid_t)) == 0) {
-            table_addr = config_tables[i].table;
+        if (memcmp(&config_tables[i].guid, &SMBIOS3_GUID, sizeof(efi_guid_t)) == 0) {
+            v3 = config_tables[i].table;
+        } else if (memcmp(&config_tables[i].guid, &SMBIOS2_GUID, sizeof(efi_guid_t)) == 0) {
+            v2 = config_tables[i].table;
         }
     }
-    return (smbiosv2_t *) table_addr;
+    if (v3) { if (is_v3) *is_v3 = 1; return v3; }
+    if (is_v3) *is_v3 = 0;
+    return v2;
+}
+static smbiosv2_t *find_smbiosv2_in_efi64_system_table(efi64_system_table_t *system_table)
+{
+    int v3 = 0;
+    uintptr_t ep = find_smbios_ep_efi64(system_table, &v3);
+    if (v3) return NULL;   // caller handles v3 separately
+    return (smbiosv2_t *) ep;
 }
 #endif
 
@@ -72,6 +128,28 @@ static smbiosv2_t *find_smbiosv2_in_efi32_system_table(efi32_system_table_t *sys
     return (smbiosv2_t *) table_addr;
 }
 
+// Locate SMBIOS v3 entry point (64-bit table). Mirrors find_smbiosv2_adr
+// but returns the v3 anchor address (or 0 if none). EFI64 path only —
+// T2 Macs always boot as EFI64.
+static uintptr_t find_smbios3_adr(void)
+{
+#if (ARCH_BITS == 64)
+    const boot_params_t *boot_params = (boot_params_t *) boot_params_addr;
+    const efi_info_t *efi_info = &boot_params->efi_info;
+    if (efi_info->loader_signature != EFI64_LOADER_SIGNATURE) return 0;
+
+    uintptr_t system_table_addr = (uintptr_t) efi_info->sys_tab_hi << 32 | (uintptr_t) efi_info->sys_tab;
+    system_table_addr = map_region(system_table_addr, sizeof(efi64_system_table_t), true);
+    if (system_table_addr == 0) return 0;
+
+    int is_v3 = 0;
+    uintptr_t ep = find_smbios_ep_efi64((efi64_system_table_t *)system_table_addr, &is_v3);
+    return is_v3 ? ep : 0;
+#else
+    return 0;
+#endif
+}
+
 static uintptr_t find_smbiosv2_adr(void)
 {
     const boot_params_t *boot_params = (boot_params_t *) boot_params_addr;
@@ -185,8 +263,47 @@ int smbios_init(void)
     smb_adr = find_smbiosv2_adr();
 
     if (smb_adr == 0) {
-        return -1;
+        // v2 not published (Apple T2 Macs). Try v3.
+        uintptr_t v3 = find_smbios3_adr();
+        smbios_init_ep_addr = v3;
+        if (v3 == 0) { smbios_init_source = -1; return -1; }
+        uintptr_t ep_mapped = map_region(v3, 0x20, true);
+        if (ep_mapped == 0) { smbios_init_source = -2; return -1; }
+        uint32_t tlen = 0;
+        uintptr_t taddr = parse_smbios3_anchor((const uint8_t *)ep_mapped, &tlen);
+        smbios_init_table_len = tlen;
+        if (taddr == 0) { smbios_init_source = -3; return -1; }
+        if (tlen == 0)  { smbios_init_source = -4; return -1; }
+        uintptr_t tmapped = map_region(taddr, tlen, true);
+        if (tmapped == 0) { smbios_init_source = -5; return -1; }
+        table_start  = (const uint8_t *)tmapped;
+
+        // SMBIOS 3 anchor gives *max* table size, not actual. The real
+        // table ends with a Type-127 (end-of-table) marker. Walking past
+        // it into the zero-padded remainder makes parse_dmi null-out
+        // dmi_system_info on its final bounds check. Pre-scan to find
+        // the real terminator and shrink table_length to that.
+        {
+            const uint8_t *p = (const uint8_t *)tmapped;
+            const uint8_t *e = p + tlen;
+            uint32_t actual = 0;
+            while (p + 4 <= e) {
+                uint8_t type = p[0];
+                uint8_t len  = p[1];
+                if (len < 4) break;   // malformed
+                p += len;
+                while (p + 1 < e && !(p[0] == 0 && p[1] == 0)) p++;
+                p += 2;
+                if (p > e) break;
+                if (type == 127) { actual = (uint32_t)(p - (const uint8_t *)tmapped); break; }
+            }
+            table_length = actual ? actual : tlen;
+        }
+        smbios_init_source = 3;
+        smbios_init_table_len = table_length;
+        return parse_dmi(0xFFFF);
     }
+    smbios_init_ep_addr = smb_adr;
 
     dmi_start = (const uint8_t *) smb_adr;
     eps = (const smbiosv2_t *) smb_adr;
@@ -200,16 +317,19 @@ int smbios_init(void)
     }
 
     if (checksum) {
+        smbios_init_source = -6;
         return -1;
     }
 
     // SMBIOS 2.3 required
     if (eps->majorversion < 2 && eps->minorversion < 3) {
+        smbios_init_source = -7;
         return -1;
     }
 
     table_start = (const uint8_t *)(uintptr_t)eps->tableaddress;
     table_length = (uint32_t)eps->tablelength;
+    smbios_init_source = 2;
 
     return parse_dmi(eps->numstructs);
 }
