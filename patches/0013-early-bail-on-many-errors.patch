--- a/app/error.c
+++ b/app/error.c
@@ -165,6 +165,67 @@ static void common_err(error_type_t type, uintptr_t addr, testword_t good, testw
 
     testword_t xor = good ^ bad;
 
+    // BRR: fail-safe error-burst detector (runs under error_mutex —
+    // all state here is single-writer, no atomics needed).
+    //
+    // On A1990 (CL-H IMC + T2) a test hitting bad DRAM cells wedges
+    // the hardware after ~150-200 errors: timer stops, all CPUs dead.
+    // We act on two signals WELL BELOW that threshold:
+    //
+    //   (a) 8 errors inside a single 1 MiB page -> record that 1 MiB
+    //       as a skip range.  Subsequent test windows prune it from
+    //       vm_map (see system/board/skip.c::board_prune_vm_map) and
+    //       never touch it again.  Flip `bail` so the current test
+    //       returns immediately.  Decoder identifies the bad chip
+    //       from 1 error; 8 is a confidence margin.
+    //
+    //   (b) 16 total errors this pass -> flip `bail` regardless.
+    //       Catches whole-chip failures whose errors scatter across
+    //       many 1 MiB pages before any single page reaches 8.
+    //
+    // HARDENING FOR HIGH ERROR RATE: test 7 block_move produces errors
+    // as fast as the IMC can drain them.  If two CPUs both hit bad
+    // cells in DIFFERENT 1 MiB regions and their errors interleave, a
+    // single last-MB counter would keep resetting and never reach 8.
+    // We carry a 4-slot LRU cache of recent MB bases so up to four
+    // concurrent bad regions each build their own run count.
+    extern bool bail;
+    extern void badmem_log_add_skip(uint64_t start_pa, uint64_t end_pa);
+
+    if (type == DATA_ERROR || type == ADDR_ERROR) {
+        #define MB_LRU_SLOTS 4
+        static struct { uintptr_t base; unsigned run; } lru[MB_LRU_SLOTS];
+        static unsigned lru_next;
+
+        uintptr_t mb_base = addr & ~((uintptr_t)0xFFFFF);
+
+        int slot = -1;
+        for (int i = 0; i < MB_LRU_SLOTS; i++) {
+            if (lru[i].base == mb_base && lru[i].run > 0) { slot = i; break; }
+        }
+        if (slot < 0) {
+            slot = (int)lru_next;
+            lru_next = (lru_next + 1u) % MB_LRU_SLOTS;
+            lru[slot].base = mb_base;
+            lru[slot].run  = 0;
+        }
+        if (lru[slot].run < 255) lru[slot].run++;
+
+        if (lru[slot].run == 8 && !bail) {
+            badmem_log_add_skip((uint64_t)mb_base,
+                                (uint64_t)mb_base + 0x100000);
+            bail = true;
+            lru[slot].base = 0;
+            lru[slot].run  = 0;
+        }
+    }
+    if (error_count >= 16 && !bail) {
+        bail = true;
+    }
+
+    extern void board_report_error(uint64_t addr, uint64_t xor_bits);
+    if (type == DATA_ERROR || type == ADDR_ERROR) board_report_error((uint64_t)addr, (uint64_t)xor);
+
     bool new_stats = false;
     testword_t page   = page_of((void *)addr);
     testword_t offset = addr & (PAGE_SIZE - 1);
