--- a/app/error.c
+++ b/app/error.c
@@ -168,6 +168,59 @@ static void common_err(error_type_t type, uintptr_t addr, testword_t good, testw
     extern void board_report_error(uint64_t addr, uint64_t xor_bits);
     if (type == DATA_ERROR || type == ADDR_ERROR) board_report_error((uint64_t)addr, (uint64_t)xor);

+    // BRR: fail-safe error-burst detector (under error_mutex — no atomics).
+    //
+    // The error has ALREADY been recorded above (board_report_error ->
+    // badmem_log_record).  This block ONLY decides whether to flip the
+    // global `bail` flag and whether to append a 1 MiB skip range; it
+    // never short-circuits recording or the display path below.
+    //
+    //   (a) 8 errors inside a single 1 MiB page -> add that 1 MiB as
+    //       a skip range (excluded from subsequent test windows via
+    //       board_prune_vm_map) and flip `bail` so the current test
+    //       returns at its next BAILOUT.  Decoder identifies the bad
+    //       chip from 1 error; 8 is a confidence margin well below
+    //       the ~150 error wedge threshold.
+    //   (b) 16 total errors this pass -> flip `bail` regardless;
+    //       catches whole-chip failures whose errors scatter across
+    //       many 1 MiB pages.
+    //
+    // Hardening for high error rate: 4-slot LRU of recent MB bases so
+    // interleaved bursts from multiple CPUs each build their own run.
+    extern bool bail;
+    extern void badmem_log_add_skip(uint64_t start_pa, uint64_t end_pa);
+
+    if (type == DATA_ERROR || type == ADDR_ERROR) {
+        #define MB_LRU_SLOTS 4
+        static struct { uintptr_t base; unsigned run; } lru[MB_LRU_SLOTS];
+        static unsigned lru_next;
+
+        uintptr_t mb_base = addr & ~((uintptr_t)0xFFFFF);
+
+        int slot = -1;
+        for (int i = 0; i < MB_LRU_SLOTS; i++) {
+            if (lru[i].base == mb_base && lru[i].run > 0) { slot = i; break; }
+        }
+        if (slot < 0) {
+            slot = (int)lru_next;
+            lru_next = (lru_next + 1u) % MB_LRU_SLOTS;
+            lru[slot].base = mb_base;
+            lru[slot].run  = 0;
+        }
+        if (lru[slot].run < 255) lru[slot].run++;
+
+        if (lru[slot].run == 8 && !bail) {
+            badmem_log_add_skip((uint64_t)mb_base,
+                                (uint64_t)mb_base + 0x100000);
+            bail = true;
+            lru[slot].base = 0;
+            lru[slot].run  = 0;
+        }
+    }
+    if (error_count >= 16 && !bail) {
+        bail = true;
+    }
+
     bool new_stats = false;
     testword_t page   = page_of((void *)addr);
     testword_t offset = addr & (PAGE_SIZE - 1);
