--- a/app/main.c
+++ b/app/main.c
@@ -733,6 +733,72 @@ void main(void)
             extern void badmem_log_dump(void);
             if (pass_num > 0)
                 badmem_log_dump();
+            // BRR: force scroll_lock OFF so pass-end prints never wait.
+            extern void set_scroll_lock(bool);
+            set_scroll_lock(false);
+            // BRR: single-threaded deferred decode of bad PAs captured
+            // during the pass (error_hook only records PA fast+AP-safe).
+            extern void board_decode_pass(void);
+            if (pass_num > 0)
+                board_decode_pass();
+            // BRR: flush accumulated bad pages to NVRAM as BrrBadPages.
+            extern void badmem_log_flush_nvram(void);
+            if (pass_num > 0)
+                badmem_log_flush_nvram();
+            // BRR: flush accumulated bad rows to BrrBadRows.
+            extern void badmem_log_flush_rows_nvram(void);
+            if (pass_num > 0)
+                badmem_log_flush_rows_nvram();
+            // BRR: auto-reboot + HALT.  Never continue to pass 2 after
+            // a real pass with errors -- would clobber NVRAM state
+            // the mask-shim needs on next boot.
+            {
+                boot_params_t *bp = (boot_params_t *)boot_params_addr;
+                extern unsigned badmem_log_count(void);
+                extern void scroll(void);
+                extern void check_input(void);
+                extern void reboot(void);
+
+                bool auto_reboot = (bp->brr_flags & (1u << 2)) != 0;
+                bool had_errors  = (pass_num > 0) && (badmem_log_count() > 0);
+
+                if (auto_reboot) {
+                    display_scrolled_message(0, "[auto] pass complete. Auto-reboot in 30s. ESC to reboot now.");
+                    scroll();
+                    for (int s = 30; s > 0; s--) {
+                        display_scrolled_message(0, "[auto] rebooting in %2d s ...", s);
+                        for (int k = 0; k < 10; k++) {
+                            usleep(100000);
+                            check_input();
+                        }
+                    }
+                    reboot();
+                    // reboot() should not return.  On T2 it sometimes
+                    // does (cf9 reset treated as shutdown / firmware
+                    // blocks ResetSystem post-EBS).  HALT rather than
+                    // fall into pass 2 which would clobber NVRAM.
+                    display_scrolled_message(0, "");
+                    scroll();
+                    display_scrolled_message(0, "*** REBOOT FAILED ***");
+                    scroll();
+                    display_scrolled_message(0, "T2 firmware rejected ResetSystem / port-cf9 reset.");
+                    scroll();
+                    display_scrolled_message(0, "NVRAM state IS written -- safe to force power cycle.");
+                    scroll();
+                    display_scrolled_message(0, "Hold power 10 s, then press power to boot USB again.");
+                    scroll();
+                    display_scrolled_message(0, "Next USB boot: mask-shim applies mask and loads macOS.");
+                    scroll();
+                    while (1) { __asm__ __volatile__("cli; hlt"); }
+                }
+                if (had_errors) {
+                    display_scrolled_message(0, "[auto] pass done with errors -- halting.");
+                    scroll();
+                    display_scrolled_message(0, "NVRAM state written. Hold power 10 s, boot USB again for shim.");
+                    scroll();
+                    while (1) { __asm__ __volatile__("cli; hlt"); }
+                }
+            }
             if (error_count == 0) {
                 display_status("Pass   ");
                 display_big_status(true);

