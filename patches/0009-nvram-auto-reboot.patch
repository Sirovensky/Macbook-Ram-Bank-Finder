@@ -737,6 +737,50 @@ void main(void)
             extern void badmem_log_dump(void);
             if (pass_num > 0)
                 badmem_log_dump();
+            // BRR: force scroll_lock OFF before any pass-end prints.
+            // T2 keyboards can inject stray keypresses (space-bar toggles
