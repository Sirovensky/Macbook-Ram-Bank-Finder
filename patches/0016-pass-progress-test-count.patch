-    if (ticks_per_pass[pass_type] > 0) {
-        pct = 100 * pass_ticks / ticks_per_pass[pass_type];
-        if (pct > 100) {
-            pct = 100;
-        }
+    // BRR: pass% = completed tests + fraction of current test.
+    // Immune to vm_map splits; bounded by design.
+    {
+        int pass_pct = (test_num * 100 + pct) / NUM_TEST_PATTERNS;
+        if (pass_pct > 100) pass_pct = 100;
