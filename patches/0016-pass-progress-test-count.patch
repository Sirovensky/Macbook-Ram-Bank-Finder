     pass_type_t pass_type = (pass_num == 0) ? FAST_PASS : FULL_PASS;
 
+    // BRR: scale test% by estimated vm_map growth.
+    // Dummy_run calibrated ticks_per_test against an UNPRUNED vm_map
+    // (one contiguous entry per memory segment).  After board_prune_vm_map
