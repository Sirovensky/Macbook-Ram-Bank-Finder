-            pct = 100;
+    {
+        extern unsigned board_skip_count_public(void);
+        unsigned nskip = board_skip_count_public();
+        int denom = ticks_per_test[pass_type][test_num] * (int)(1u + nskip);
+        if (denom > 0) {
+            pct = 100 * test_ticks / denom;
+            if (pct > 100) pct = 100;
         }
     }
     display_test_percentage(pct);
     display_test_bar((BAR_LENGTH * pct) / 100);
 
