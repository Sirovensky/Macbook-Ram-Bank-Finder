--- a/app/display.c
+++ b/app/display.c
@@ -600,14 +600,33 @@ void do_tick(int my_cpu)
     display_test_percentage(pct);
     display_test_bar((BAR_LENGTH * pct) / 100);

-    pct = 0;
-    if (ticks_per_pass[pass_type] > 0) {
-        pct = 100 * pass_ticks / ticks_per_pass[pass_type];
-        if (pct > 100) {
-            pct = 100;
-        }
-    }
-    display_pass_percentage(pct);
+    // BRR: pass progress based on completed test count, not tick ratio.
+    //
+    // The tick-ratio formula (pass_ticks / ticks_per_pass[pass_type])
+    // was calibrated during the dummy run against an untouched vm_map
+    // covering the full installed memory.  Once the burst detector
+    // (patch 0013) fires and board_prune_vm_map (patch 0015) splits
+    // vm_map entries around skip ranges, each test's outer loop does
+    // MORE iterations on the same installed memory — pass_ticks
+    // overshoots ticks_per_pass and the bar locks at 100% while only
+    // a few tests are complete.
+    //
+    // Replace with a simple "how many tests done + fraction of the
+    // current test" metric.  Bounded by design, independent of how
+    // many vm_map splits occurred.  NUM_TEST_PATTERNS is fixed at
+    // 11, so each test contributes ~9 percentage points.
+    {
+        int done = test_num;                       // 0..NUM_TEST_PATTERNS-1
+        int in_test_pct = 0;
+        if (ticks_per_test[pass_type][test_num] > 0) {
+            in_test_pct = 100 * test_ticks / ticks_per_test[pass_type][test_num];
+            if (in_test_pct > 100) in_test_pct = 100;
+        }
+        int pass_pct = (done * 100 + in_test_pct) / NUM_TEST_PATTERNS;
+        if (pass_pct > 100) pass_pct = 100;
+        display_pass_percentage(pass_pct);
+        pct = pass_pct;  // reused below for the bar
+    }
     display_pass_bar((BAR_LENGTH * pct) / 100);

     bool update_spinner = true;
